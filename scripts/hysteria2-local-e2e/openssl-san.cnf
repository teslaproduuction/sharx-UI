# Self-signed server cert for local Hy2 / Xray tests.
# SAN must include the SNI the client uses (e.g. vk.com) and 127.0.0.1 when connecting to loopback.

[req]
distinguished_name = req_distinguished_name
x509_extensions = v3_req
prompt = no

[req_distinguished_name]
CN = vk.com
O = SharX-Hy2-E2E

[v3_req]
subjectAltName = @alt_names
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = vk.com
DNS.2 = localhost
IP.1 = 127.0.0.1
