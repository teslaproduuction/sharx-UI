{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": { "udp": true }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "hysteria",
      "settings": {
        "version": 2,
        "address": "SERVER_HOST_OR_IP",
        "port": 29192
      },
      "streamSettings": {
        "network": "hysteria",
        "security": "tls",
        "tlsSettings": {
          "serverName": "vk.com",
          "alpn": ["h3"],
          "allowInsecure": true,
          "fingerprint": "chrome"
        },
        "hysteriaSettings": {
          "version": 2,
          "auth": "CHANGE_ME_SAME_AS_SERVER_CLIENT_AUTH",
          "udpIdleTimeout": 60
        }
      }
    },
    { "tag": "direct", "protocol": "freedom", "settings": {} }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      { "type": "field", "inboundTag": ["socks-in"], "outboundTag": "proxy" }
    ]
  }
}
