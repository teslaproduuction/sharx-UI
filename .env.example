# SharX environment template — copy to .env and fill in real values.
# .env IS gitignored. Never commit real values.
# Use `bash scripts/install-sharx.sh` for an interactive setup that generates this for you.

# === Panel runtime ===
XUI_DEBUG=true
XUI_DB_FOLDER=x-ui
XUI_LOG_FOLDER=x-ui
XUI_BIN_FOLDER=x-ui

# === Phase 1 — Caddy front-door ===

# Public hostname pointing to this server (must have DNS A/AAAA record).
# Leave EMPTY for IP-mode (Caddy uses internal CA, browsers see self-signed warning).
# Example: dev.example.com
PANEL_DOMAIN=

# Random URL prefix that hides the panel UI. The script generates this automatically.
# Browse to https://<PANEL_DOMAIN>/<PANEL_SECRET_PREFIX>/ to reach the panel.
# Anyone hitting any other path gets the decoy site.
# Generate with: openssl rand -hex 8
PANEL_SECRET_PREFIX=

# Upstream URL Caddy transparently mirrors for all unrecognized paths (Hiddify pattern).
# Pick any plausible site that returns reasonable content; avoid sites that block hotlinking.
# Examples: https://news.ycombinator.com, https://en.wikipedia.org, https://archive.org
PANEL_DECOY_URL=https://news.ycombinator.com

# === Watchtower ===

# Bearer token for the in-stack updater (panel calls Watchtower HTTP API).
# Generate with: openssl rand -hex 24
WATCHTOWER_HTTP_API_TOKEN=
