# /x-ui

# # Ignore OS specific files
# .DS_Store
# Thumbs.db

# # Ignore Go build files
# *.exe
# x-ui.db

# Local-only docker overrides
docker-compose.override.yml

# Environment files — MUST NOT be committed (contain secrets: domain, prefixes, tokens)
.env
.env.local
.env.*.local
!.env.example.agent.zip
data/geofile-assets/
