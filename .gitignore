# Ignore editor and IDE settings
.idea/
.vscode/
.cache/
.sync*

# Ignore log files
*.log

# Ignore local scripts (keep locally but don't commit)
push-harbor.sh

# Ignore temporary files
tmp/
*.tar.gz

# Local agent workspace (notes, plans, scratch)
.agent/

# Ignore build and distribution directories
backup/
bin/
dist/
release/
